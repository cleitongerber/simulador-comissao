# Porta local opcional
PORT=3000

# Use a URL Postgres de Render, Railway, Supabase, Neon etc.
# Sem DATABASE_URL, o app salva localmente em data/state.json.
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Use false apenas se seu provedor Postgres nao exigir SSL.
PGSSL=true

# Senha admin inicial quando o banco ainda esta vazio.
ADMIN_PASSWORD=admin123
